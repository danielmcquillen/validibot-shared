{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.validibot.com/portfolio-manager/expected-buildings-list-v1.schema.json",
  "title": "Validibot Portfolio Manager Expected Buildings List",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id_field", "euit_unit", "buildings"],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "id_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": [
            "property_id",
            "parent_property_id",
            "standard_id",
            "custom_id"
          ]
        },
        "name": {
          "type": "string",
          "maxLength": 255
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "enum": ["standard_id", "custom_id"]
              }
            }
          },
          "then": {
            "required": ["name"],
            "properties": {
              "name": {
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "euit_unit": {
      "const": "kBtu/ft2/year"
    },
    "buildings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id_value"],
        "properties": {
          "id_value": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "euit": {
            "type": "string",
            "pattern": "^(?:0*[1-9][0-9]*(?:\\.[0-9]+)?|0*\\.[0-9]*[1-9][0-9]*)$"
          }
        }
      }
    }
  }
}
